{
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "healthcheckPath": "/health",
    "healthcheckTimeout": 30,
    "command": "cd backend && pip install -r requirements.txt && uvicorn main:app --host 0.0.0.0 --port $PORT"
  },
  "cron": {
    "proactive-check": {
      "schedule": "*/30 * * * *",
      "command": "curl -s -X POST https://$RAILWAY_PUBLIC_DOMAIN/cron/proactive -H 'X-Cron-Key: $CRON_SECRET_KEY'"
    }
  }
}
